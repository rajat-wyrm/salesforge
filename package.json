{
  "name": "salesforge",
  "private": true,
  "version": "1.0.0",
  "description": "SalesForge full-stack workspace",
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "install": "npm --prefix backend install",
    "build": "cd frontend && npm install && npm run build",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:backend": "npm --prefix backend test",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:seed": "npm --prefix backend run prisma:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "razorpay": "^2.9.8"
  }
}
