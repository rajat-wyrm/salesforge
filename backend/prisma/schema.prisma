  org       Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type      EmailEventType
  recipient String
  subject   String?
  messageId String?
  link      String?
  linkLabel String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime       @default(now())

  @@index([orgId, type])
  @@index([recipient])
  @@index([createdAt])
  @@map("email_events")
}

// ============================================================
//  OSINT & SALES INTELLIGENCE HUB SEARCHES
// ============================================================

model IntelSearch {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  module    String       // e.g. "email_intelligence", "domain_intelligence"
  query     String
  filters   Json?        @default("{}")
  results   Json
