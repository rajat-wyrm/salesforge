  userId      Int
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String // "slack", "gmail", "outlook", "linkedin", "google_calendar", "zoom", "stripe"
  name        String
  config      Json?
  credentials Json?
  status      String        @default("connected")
  lastSyncAt  DateTime?
