generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
//  USER & ORG
// ============================================================

enum UserRole {
  ADMIN
  STARTUP
  INVESTOR
  OWNER
  MEMBER
  VIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OrgPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model User {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  password       String
  googleId String? @unique
   avatar   String?
   provider String?
  role           UserRole      @default(MEMBER)
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  passwordResetToken       String?
  passwordResetExpires     DateTime?
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  emailOtpLastSentAt       DateTime?
  isVerified               Boolean   @default(false)

  mobile                    String?   @unique
  mobileVerificationToken   String?
  otpRequestedAt            DateTime?
  mobileVerificationExpires DateTime?
  isMobileVerified          Boolean   @default(false)

  // Security
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?

  // Flexible JSON store for quotas, commissions, territory, and other
  // user-level customizations. Avoids creating a new model for each
  // feature while still allowing rich per-user data.
  customFields Json? @default("{}")

  // Relations
  orgMemberships          OrgMembership[]
  leadsAdded              Lead[]                   @relation("AddedByUser")
  leadsAssigned           Lead[]                   @relation("AssignedToUser")
  activityLogs            ActivityLog[]
  analyticsEvents         AnalyticsEvent[]
  notifications           Notification[]
  sessions                Session[]
  apiKeys                 ApiKey[]
  webhooks                Webhook[]
  savedSearches           SavedSearch[]
  leadNotes               LeadNote[]
  leadTasks               LeadTask[]               @relation("TaskAssignee")
  leadTasksCreated        LeadTask[]               @relation("TaskCreator")
  leadActivities          LeadActivity[]
  auditLogs               AuditLog[]
  teamInvitesSent         TeamInvite[]             @relation("InviteSender")
  usageRecords            UsageRecord[]
  subscription            Subscription?
  payments                Payment[]
  tags                    Tag[]
  activities              Activity[]
  calendarEvents          CalendarEvent[]
  emailTemplates          EmailTemplate[]
  sequences               Sequence[]
  workflows               Workflow[]
  comments                Comment[]
  notificationPreferences NotificationPreference[]
  integrations            Integration[]
  forecasts               Forecast[]
  reports                 Report[]
  onboardingProgress      OnboardingProgress[]
  invoices                Invoice[]
  products                Product[]
  priceBooks              PriceBook[]
  quotes                  Quote[]                  @relation("QuoteCreator")
  playbooks               Playbook[]               @relation("PlaybookCreator")
  winLossRecords          WinLossRecord[]          @relation("WinLossRecorder")
  intelSearches           IntelSearch[]
  fcmTokens               FcmToken[]

  @@map("users")
}

model Organization {
  id           Int       @id @default(autoincrement())
  name         String
  slug         String    @unique
  website      String?   @default("")
  region       String?   @default("Global")
  type         String?   @default("Startup")
  contactName  String?   @default("")
  contactEmail String?
  logo         String?
  plan         OrgPlan   @default(FREE)
  status       OrgStatus @default(TRIALING)
  trialEndsAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users                   User[]
  memberships             OrgMembership[]
  leads                   Lead[]
  deals                   DealStartup[]
  dealInvestors           DealInvestor[]
  apiKeys                 ApiKey[]
  webhooks                Webhook[]
  savedSearches           SavedSearch[]
  leadNotes               LeadNote[]
  leadTasks               LeadTask[]
  leadActivities          LeadActivity[]
  tags                    Tag[]
  auditLogs               AuditLog[]
  teamInvites             TeamInvite[]
  subscription            Subscription?
  payments                Payment[]
  usageRecords            UsageRecord[]
  pipelineStages          PipelineStage[]
  activities              Activity[]
  calendarEvents          CalendarEvent[]
  emailTemplates          EmailTemplate[]
  sequences               Sequence[]
  workflows               Workflow[]
  customFields            CustomField[]
  comments                Comment[]
  notificationPreferences NotificationPreference[]
  integrations            Integration[]
  forecasts               Forecast[]
  reports                 Report[]
  onboardingProgress      OnboardingProgress[]
  invoices                Invoice[]
  products                Product[]
  priceBooks              PriceBook[]
  quotes                  Quote[]
  playbooks               Playbook[]
  winLossRecords          WinLossRecord[]
  emailEvents             EmailEvent[]
  intelSearches           IntelSearch[]

  @@map("organizations")
}

model OrgMembership {
  id       Int          @id @default(autoincrement())
  userId   Int
  orgId    Int
  role     OrgRole      @default(MEMBER)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  joinedAt DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_memberships")
}

model TeamInvite {
  id          Int          @id @default(autoincrement())
  orgId       Int
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email       String
  role        OrgRole      @default(MEMBER)
  token       String       @unique
  invitedById Int
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id])
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([orgId])
  @@index([email])
  @@map("team_invites")
}

// ============================================================
//  SESSIONS & SECURITY
// ============================================================

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  location     String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("sessions")
}

// ============================================================
//  SUBSCRIPTION & BILLING
// ============================================================

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

model Subscription {
  id                   Int                @id @default(autoincrement())
  userId               Int                @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId                Int?               @unique
  org                  Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  plan                 OrgPlan            @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("subscriptions")
}

model Payment {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId           Int?
  org             Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  description     String?
  stripePaymentId String?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([orgId])
  @@map("payments")
}

model UsageRecord {
  id        Int           @id @default(autoincrement())
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  resource  String // leads, searches, api_calls, etc.
  count     Int           @default(1)
  period    String // YYYY-MM
  metadata  Json?
  createdAt DateTime      @default(now())

  @@unique([userId, orgId, resource, period])
  @@index([orgId, period])
  @@map("usage_records")
}

// ============================================================
//  LEADS
// ============================================================

enum LeadStatus {
  new
  contacted
  qualified
  converted
  lost
  in_progress
  closed
}

enum LeadSource {
  website
  referral
  social_media
  email_campaign
  cold_call
  trade_show
  partner
  other
  import
  api
  database_search
  domain_search
  email_search
  social_search
}

model Lead {
  id              Int           @id @default(autoincrement())
  orgId           Int?
  org             Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  name            String
  email           String        @unique
  phone           String?
  domain          String?
  jobTitle        String?
  managementLevel String?
  department      String?
  location        String?
  industry        String?
  skills          String?
  companyLocation String?
  companySize     String?
  revenue         String?
  companyName     String?

  status LeadStatus @default(new)
  source LeadSource @default(other)

  followupSent Boolean   @default(false)
  contactedAt  DateTime?

  engagement   Json?
  score        Int   @default(0)
  scoreDetails Json?

  addedById    Int?
  addedBy      User? @relation("AddedByUser", fields: [addedById], references: [id])
  assignedToId Int?
  assignedTo   User? @relation("AssignedToUser", fields: [assignedToId], references: [id])

  notes      LeadNote[]
  tasks      LeadTask[]
  activities LeadActivity[]
  tags       LeadTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([orgId])
  @@index([assignedToId])
  @@map("leads")
}

model LeadNote {
  id        Int           @id @default(autoincrement())
  leadId    Int
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model LeadTask {
  id          Int           @id @default(autoincrement())
  leadId      Int
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      Int
  user        User          @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdById Int
  createdBy   User          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([status])
  @@map("lead_tasks")
}

enum ActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  NOTE_ADDED
  TASK_CREATED
  TASK_COMPLETED
  EMAIL_SENT
  CALL_MADE
  MEETING_SCHEDULED
  SCORE_CHANGED
  TAG_ADDED
  TAG_REMOVED
}

model LeadActivity {
  id        Int           @id @default(autoincrement())
  leadId    Int
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  type      ActivityType
  title     String
  body      String?
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([leadId])
  @@index([createdAt])
  @@map("lead_activities")
}

model Tag {
  id        Int           @id @default(autoincrement())
  name      String
  slug      String
  color     String        @default("#3b82f6")
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  leads     LeadTag[]
  createdAt DateTime      @default(now())

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("tags")
}

model LeadTag {
  id     Int  @id @default(autoincrement())
  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tagId  Int
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@map("lead_tags")
}

// ============================================================
//  DEALS
// ============================================================

enum DealStage {
  NEW
  NEGOTIATION
  DUE_DILIGENCE
  CLOSED
  CANCELLED
}

enum DealStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

model Deal {
  id              Int            @id @default(autoincrement())
  orgId           Int?
  amount          Float
  title           String?
  stage           DealStage      @default(NEW)
  status          DealStatus     @default(ACTIVE)
  startups        DealStartup[]
  investors       DealInvestor[]
  stageId         Int?
  stageRef        PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  position        Int            @default(0)
  probability     Int            @default(50)
  expectedCloseAt DateTime?
  closedAt        DateTime?
  source          String?
  ownerId         Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("deals")
}

model DealStartup {
  id     Int          @id @default(autoincrement())
  dealId Int
  orgId  Int
  deal   Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([dealId, orgId])
  @@map("deal_startups")
}

model DealInvestor {
  id     Int          @id @default(autoincrement())
  dealId Int
  orgId  Int
  deal   Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([dealId, orgId])
  @@map("deal_investors")
}

// ============================================================
//  API KEYS & WEBHOOKS
// ============================================================

model ApiKey {
  id         Int           @id @default(autoincrement())
  name       String
  keyHash    String        @unique
  keyPrefix  String
  orgId      Int?
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId     Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes     String        @default("read,write")
  active     Boolean       @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())

  @@index([keyHash])
  @@index([orgId])
  @@map("api_keys")
}

enum WebhookEvent {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_DELETED
  LEAD_STATUS_CHANGED
  DEAL_CREATED
  DEAL_UPDATED
  ORGANIZATION_CREATED
  USER_INVITED
  USER_JOINED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  SUBSCRIPTION_UPDATED
  SEARCH_COMPLETED
  INTEGRATION_SYNCED
}

model Webhook {
  id            Int               @id @default(autoincrement())
  name          String
  url           String
  secret        String
  orgId         Int?
  org           Organization?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId        Int
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        String // comma-separated
  active        Boolean           @default(true)
  lastTriggered DateTime?
  failureCount  Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deliveries    WebhookDelivery[]

  @@index([orgId])
  @@map("webhooks")
}

model WebhookDelivery {
  id             Int      @id @default(autoincrement())
  webhookId      Int
  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  error          String?
  durationMs     Int?
  createdAt      DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// ============================================================
//  SAVED SEARCHES & VIEWS
// ============================================================

model SavedSearch {
  id        Int           @id @default(autoincrement())
  name      String
  resource  String // leads, organizations, etc.
  filters   Json
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isShared  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([orgId, resource])
  @@index([userId])
  @@map("saved_searches")
}

// ============================================================
//  BLOCKCHAIN
// ============================================================

model BlockchainTransaction {
  id              Int      @id @default(autoincrement())
  recordId        String
  dataHash        String
  transactionHash String   @unique
  blockNumber     Int
  timestamp       DateTime @default(now())
  networkName     String   @default("sepolia")
  status          String   @default("pending")
  gasUsed         String?
  errorMessage    String?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([recordId])
  @@index([transactionHash])
  @@index([status])
  @@map("blockchain_transactions")
}

// ============================================================
//  ORGANIZATION TYPES
// ============================================================

model OrganizationType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organization_types")
}

// ============================================================
//  AUDIT LOGS
// ============================================================

model AuditLog {
  id         Int           @id @default(autoincrement())
  userId     Int?
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  orgId      Int?
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json          @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   Int?
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@map("activity_logs")
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orgId     Int?
  type      String
  resource  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([orgId])
  @@index([createdAt])
  @@map("analytics_events")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  is_read   Boolean   @default(false)
  readAt    DateTime?
  link      String?
  metadata  Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([type])
  @@index([is_read])
  @@map("notifications")
}

model EmailSearch {
  id         Int      @id @default(autoincrement())
  email      String
  domain     String
  valid      Boolean  @default(false)
  verifiedBy String?
  userId     Int?
  orgId      Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([orgId])
  @@map("email_searches")
}

model DomainSearch {
  id             Int      @id @default(autoincrement())
  domain         String
  status         String   @default("active")
  expirationDate String?
  dnsRecords     Json     @default("{\"A\": [], \"MX\": [], \"NS\": []}")
  userId         Int?
  orgId          Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([orgId])
  @@map("domain_searches")
}

// ============================================================
//  PIPELINE STAGES & DEALS
// ============================================================

model PipelineStage {
  id          Int           @id @default(autoincrement())
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  color       String        @default("gray")
  position    Int           @default(0)
  probability Int           @default(50)
  isWon       Boolean       @default(false)
  isLost      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  deals Deal[]

  @@index([orgId, position])
  @@map("pipeline_stages")
}

// ============================================================
//  ACTIVITIES (calls, meetings, tasks at org level)
// ============================================================

enum ActivityEntityType {
  LEAD
  DEAL
  CONTACT
  COMPANY
  ORGANIZATION
}

enum ActivityKind {
  CALL
  MEETING
  TASK
  EMAIL_SENT
  EMAIL_RECEIVED
  NOTE
  LINKEDIN
  WHATSAPP
  SMS
}

enum ActivityStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  OVERDUE
  IN_PROGRESS
}

model Activity {
  id          Int                @id @default(autoincrement())
  orgId       Int?
  org         Organization?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      Int
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        ActivityKind
  status      ActivityStatus     @default(SCHEDULED)
  entityType  ActivityEntityType
  entityId    Int
  title       String
  description String?
  outcome     String?
  dueAt       DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([orgId, kind])
  @@index([userId, status])
  @@index([entityType, entityId])
  @@index([dueAt])
  @@map("activities")
}

// ============================================================
//  CALENDAR EVENTS
// ============================================================

model CalendarEvent {
  id          Int           @id @default(autoincrement())
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      Int
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean       @default(false)
  location    String?
  meetingUrl  String?
  attendees   Json?
  relatedTo   String?
  relatedId   Int?
  color       String        @default("teal")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orgId, startAt])
  @@index([userId, startAt])
  @@map("calendar_events")
}

// ============================================================
//  EMAIL TEMPLATES & SEQUENCES
// ============================================================

model EmailTemplate {
  id        Int           @id @default(autoincrement())
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  body      String        @db.Text
  category  String?
  variables Json?
  isShared  Boolean       @default(false)
  useCount  Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([orgId])
  @@map("email_templates")
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  STOPPED
  REPLIED
  BOUNCED
}

model Sequence {
  id          Int                  @id @default(autoincrement())
  orgId       Int?
  org         Organization?        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      Int
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      SequenceStatus       @default(DRAFT)
  steps       Json
  metrics     Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  enrollments SequenceEnrollment[]

  @@index([orgId])
  @@map("sequences")
}

model SequenceEnrollment {
  id          Int              @id @default(autoincrement())
  sequenceId  Int
  sequence    Sequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   Int?
  leadId      Int?
  email       String
  status      EnrollmentStatus @default(ACTIVE)
  currentStep Int              @default(0)
  steps       Json
  nextRunAt   DateTime?
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([sequenceId, status])
  @@index([nextRunAt])
  @@map("sequence_enrollments")
}

// ============================================================
//  WORKFLOWS (Automation Rules)
// ============================================================

enum WorkflowTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_SCORE_CHANGED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  ACTIVITY_COMPLETED
  FORM_SUBMITTED
  EMAIL_OPENED
  EMAIL_REPLIED
  SCHEDULED_TIME
  WEBHOOK_RECEIVED
}

enum WorkflowAction {
  SEND_EMAIL
  CREATE_TASK
  UPDATE_FIELD
  ASSIGN_OWNER
  ADD_TAG
  REMOVE_TAG
  NOTIFY_USER
  CREATE_DEAL
  WEBHOOK
  WAIT
  BRANCH
}

model Workflow {
  id          Int             @id @default(autoincrement())
  orgId       Int?
  org         Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     WorkflowTrigger
  conditions  Json?
  actions     Json
  active      Boolean         @default(true)
  runCount    Int             @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  runs WorkflowRun[]

  @@index([orgId, trigger])
  @@index([active])
  @@map("workflows")
}

model WorkflowRun {
  id          Int       @id @default(autoincrement())
  workflowId  Int
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String    @default("running")
  trigger     String
  entityType  String
  entityId    Int?
  log         Json
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  error       String?

  @@index([workflowId])
  @@index([status])
  @@map("workflow_runs")
}

// ============================================================
//  CUSTOM FIELDS
// ============================================================

model CustomField {
  id        Int           @id @default(autoincrement())
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entity    String // "lead", "deal", "contact", "company"
  name      String
  slug      String
  label     String
  type      String // "text", "number", "select", "multiselect", "date", "checkbox", "url", "email"
  options   Json?
  required  Boolean       @default(false)
  position  Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([orgId, entity, slug])
  @@index([orgId, entity])
  @@map("custom_fields")
}

// ============================================================
//  COMMENTS & MENTIONS
