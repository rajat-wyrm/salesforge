model Invoice {
  id        Int           @id @default(autoincrement())
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  number    String        @unique
  amount    Float
  tax       Float         @default(0)
  total     Float
  currency  String        @default("USD")
  status    String        @default("draft") // "draft", "open", "paid", "void", "uncollectible"
  items     Json
  issuedAt  DateTime      @default(now())
  dueAt     DateTime?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([orgId])
  @@map("invoices")
}

// Update existing models to add the new relations
// User now has: pipelines, stages, activities, calendar, templates, sequences, workflows, comments, notifPrefs, integrations, forecasts, reports, onboarding, invoices
// Organization now has: stages, activities, calendar, templates, sequences, workflows, customFields, comments, notifPrefs, integrations, forecasts, reports, onboarding, invoices

// ============================================================
//  PRODUCTS & PRICE BOOKS
// ============================================================

model Product {
  id          Int           @id @default(autoincrement())
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  sku         String
  description String?       @db.Text
  category    String?
  unitPrice   Float         @default(0)
  cost        Float         @default(0)
  currency    String        @default("USD")
  isActive    Boolean       @default(true)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  priceBookEntries PriceBookEntry[]
  quoteItems       QuoteItem[]
  user             User?            @relation(fields: [userId], references: [id])
  userId           Int?

  @@unique([orgId, sku])
  @@index([orgId, category])
  @@map("products")
}

model PriceBook {
  id        Int           @id @default(autoincrement())
  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  currency  String        @default("USD")
  isDefault Boolean       @default(false)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  entries PriceBookEntry[]
  user    User?            @relation(fields: [userId], references: [id])
  userId  Int?

  @@index([orgId])
  @@map("price_books")
}

model PriceBookEntry {
  id          Int       @id @default(autoincrement())
  priceBookId Int
  priceBook   PriceBook @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitPrice   Float
  minQuantity Int       @default(1)

  @@unique([priceBookId, productId])
  @@map("price_book_entries")
}

// ============================================================
//  QUOTES & PROPOSALS
// ============================================================

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  REVISED
}

model Quote {
  id          Int           @id @default(autoincrement())
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dealId      Int?
  number      String        @unique
  title       String
  description String?       @db.Text
  status      QuoteStatus   @default(DRAFT)
  subtotal    Float         @default(0)
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float         @default(0)
  currency    String        @default("USD")
  validUntil  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  notes       String?       @db.Text
  terms       String?       @db.Text
  metadata    Json?
  createdById Int
  createdBy   User          @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items  QuoteItem[]
  events QuoteEvent[]

  @@index([orgId, status])
  @@index([dealId])
  @@map("quotes")
}

model QuoteItem {
  id          Int      @id @default(autoincrement())
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Float
  discount    Float    @default(0)
  total       Float
  position    Int      @default(0)

  @@index([quoteId])
  @@map("quote_items")
}

model QuoteEvent {
  id        Int      @id @default(autoincrement())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  type      String // SENT, VIEWED, ACCEPTED, REJECTED, COMMENTED
  actor     String? // email/name of viewer
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([quoteId, type])
  @@map("quote_events")
}

// ============================================================
//  SALES PLAYBOOKS
// ============================================================

model Playbook {
  id          Int           @id @default(autoincrement())
  orgId       Int?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?       @db.Text
  category    String        @default("general") // "general", "competitor", "objection", "discovery"
  tags        String? // comma-separated
  isPublished Boolean       @default(true)
  createdById Int
  createdBy   User          @relation("PlaybookCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  steps PlaybookStep[]

  @@index([orgId, category])
  @@map("playbooks")
}

model PlaybookStep {
  id         Int      @id @default(autoincrement())
  playbookId Int
  playbook   Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  type       String   @default("text") // "text", "checklist", "question", "tip", "warning"
  position   Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([playbookId, position])
  @@map("playbook_steps")
}

// ============================================================
//  WIN/LOSS ANALYSIS
// ============================================================

enum DealOutcome {
  WON
  LOST
  POSTPONED
  CANCELLED
}

enum LossReason {
  PRICE
  COMPETITOR
  NO_BUDGET
  NO_DECISION
  TIMING
  NO_RESPONSE
  FEATURES
  RELATIONSHIP
  OTHER
}

model WinLossRecord {
  id           Int           @id @default(autoincrement())
  orgId        Int?
  org          Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dealId       Int?          @unique
  outcome      DealOutcome
  lossReason   LossReason?
  competitor   String?
  amount       Float
  closedAt     DateTime
  cycleDays    Int?
  notes        String?       @db.Text
  lessons      String?       @db.Text
  metadata     Json?
  recordedById Int
  recordedBy   User          @relation("WinLossRecorder", fields: [recordedById], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orgId, outcome])
  @@index([orgId, lossReason])
  @@map("win_loss_records")
}

// ============================================================
//  EMAIL TRACKING
