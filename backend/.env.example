# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres1234@localhost:5432/salesforge"

# Auth
JWT_SECRET=replace-with-a-long-random-secret-in-production
JWT_EXPIRE=7d

# CORS allowed origin for the SPA
FRONTEND_URL=http://localhost:5173

# Email (optional - transactional mail)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Twilio (optional - SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe (optional - billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 (optional - file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=

# AI / OpenAI (optional - lead scoring)
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash